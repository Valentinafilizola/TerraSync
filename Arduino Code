// Pin definitions
const int lightSensorPin = A0;   // photoresistor
const int buttonPin = 2;         // button

// LED pins
const int led1 = 9;   // white LED
const int led2 = 10;  // white LED
const int led3 = 11;  // yellow LED

void setup() {

  Serial.begin(9600);

  pinMode(buttonPin, INPUT_PULLUP);

  pinMode(led1, OUTPUT);
  pinMode(led2, OUTPUT);
  pinMode(led3, OUTPUT);
}

void loop() {

  // Read the photoresistor
  int lightValue = analogRead(lightSensorPin); // 0–1023

  // Read the button
  int buttonState = digitalRead(buttonPin);

  int buttonPressed = 0;
  if (buttonState == LOW) {
    buttonPressed = 1;
  }

  // --- NEW: constrain light range so dimming starts earlier ---
  int constrainedLight = constrain(lightValue, 0, 600);

  // Dark -> bright LEDs
  int brightness = map(constrainedLight, 0, 600, 255, 0);

  // Set LED brightness
  analogWrite(led1, brightness);
  analogWrite(led2, brightness);
  analogWrite(led3, brightness);

  // Send sensor data to Unity
  Serial.print(lightValue);
  Serial.print(",");
  Serial.println(buttonPressed);

  delay(20);
}
